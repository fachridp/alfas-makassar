<div class="container mt-3">
  <div class="row">
    <div class="col-md-6">
      <h2>Form Tambah Transaksi</h2>
      <form method="post" action="/transactions" class="mt-3">
        <div class="mb-3">
          <label for="tanggal" class="form-label">Tanggal</label>
          <input
            type="date"
            class="form-control"
            id="tanggal"
            name="tanggal"
autocomplete="off" 
            required
          />
        </div>
        <div class="mb-3">
          <label for="nama_barang" class="form-label">Nama Barang</label>
          <input
            type="text"
            class="form-control"
            id="nama_barang"
            name="nama_barang"
autocomplete="off"
            required
          />
        </div>
        <div class="mb-3">
          <label for="harga_satuan" class="form-label">Harga Satuan</label>
          <input
            type="text"
            class="form-control"
            id="harga_satuan"
            name="harga_satuan"
autocomplete="off"
            required
          />
        </div>
        <div class="mb-3">
          <label for="jumlah_barang" class="form-label">Jumlah Dibeli</label>
          <input
            type="text"
            class="form-control"
            id="jumlah_barang"
            name="jumlah_barang"
autocomplete="off"
            required
          />
        </div>
        <div class="mb-3">
          <label for="total_bayar" class="form-label">Total Bayar</label>
          <input
            type="text"
            class="form-control"
            id="total_bayar"
            name="total_bayar"
autocomplete="off"
	    required
          />
        </div>
        <a href="/transactions" class="btn btn-danger">Kembali</a>
        <button type="submit" class="btn btn-success">Tambah Transaksi</button>
      </form>
    </div> 
  </div>
</div>
